class Solution {
public:
    int maximumGap(vector<int>& nums) {
        int n=nums.size();
        int maxno=INT_MIN;
        sort(nums.begin(),nums.end());
        int diff=0;
        if(n==0 || n==1)return 0;
        for(int i=1; i<n; i++){
             diff=nums[i]-nums[i-1];
            maxno=max(maxno,diff);
        }
        return abs(maxno);
    }
};
